{
  "name": "gradia-capture",
  "version": "1.1.0",
  "description": "GNOME Shell extension for screenshot annotation with Gradia OCR integration",
  "type": "module",
  "scripts": {
    "build": "./scripts/build.sh",
    "dev": "./scripts/dev.sh",
    "gettext": "./scripts/gettext.sh",
    "gettext:extract": "./scripts/gettext.sh extract",
    "gettext:update": "./scripts/gettext.sh update",
    "gettext:compile": "./scripts/gettext.sh compile",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "check": "npm run lint && npm run fmt:check"
  },
  "devDependencies": {
    "oxlint": "^1.73.0",
    "oxfmt": "^0.58.0"
  }
}
